{{/*
  PREVIEW secrets template.

  Differs from ../10.app/secrets.ctmpl in two deliberate ways:

  1. NO postgres block. A preview stack uses its OWN ephemeral postgres (the `db`
     service in this dir's compose.yaml); DATABASE_URL is overridden by the web/llm
     entrypoints to point there, so Vault must NOT render a DATABASE_URL for the shared
     truealpha-postgres.

  2. App secrets (SEC_USER_AGENT, ANTHROPIC_API_KEY, S3) are read from a FIXED source
     env — controlled by PREVIEW_SECRET_ENV (default "staging") — NOT from the per-alias
     ENV. A preview alias is ephemeral (pr-5, commit-1ab32d5, ...) and has no Vault path
     of its own; reusing staging's app secrets keeps every alias functional without
     provisioning a Vault path per alias. The preview AppRole's policy must grant read on
     this source path (see vault-policy.hcl) — that is a one-time live setup.
*/ -}}
{{- $src := or (env "PREVIEW_SECRET_ENV") "staging" -}}
{{- with secret (printf "secret/data/truealpha/%s/app" $src) }}
APP_ENV={{ with .Data.data.APP_ENV }}{{ printf "%q" . }}{{ else }}"preview"{{ end }}
SEC_USER_AGENT={{ with .Data.data.SEC_USER_AGENT }}{{ printf "%q" . }}{{ else }}""{{ end }}
ANTHROPIC_API_KEY={{ with .Data.data.ANTHROPIC_API_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
{{- /* S3-compatible raw archive, same source-env borrow as the other app secrets. */}}
S3_ENDPOINT={{ with .Data.data.S3_ENDPOINT }}{{ printf "%q" . }}{{ else }}""{{ end }}
S3_ACCESS_KEY={{ with .Data.data.S3_ACCESS_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
S3_SECRET_KEY={{ with .Data.data.S3_SECRET_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
S3_BUCKET={{ with .Data.data.S3_BUCKET }}{{ printf "%q" . }}{{ else }}"truealpha-raw"{{ end }}
S3_REGION={{ with .Data.data.S3_REGION }}{{ printf "%q" . }}{{ else }}"us-east-1"{{ end }}
{{- end }}
