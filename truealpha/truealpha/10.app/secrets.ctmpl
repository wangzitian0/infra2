{{- $env := env "ENV" -}}
{{- $env_suffix := "" -}}
{{- if ne $env "production" -}}
  {{- $env_suffix = printf "-%s" $env -}}
{{- end -}}
{{- with secret (printf "secret/data/truealpha/%s/postgres" $env) -}}
  {{- $pg_password := .Data.data.POSTGRES_PASSWORD }}
DATABASE_URL="{{ printf "postgresql://postgres:%s@truealpha-postgres%s:5432/truealpha" $pg_password $env_suffix }}"
{{ end -}}
{{- with secret (printf "secret/data/truealpha/%s/app" $env) }}
APP_ENV={{ with .Data.data.APP_ENV }}{{ printf "%q" . }}{{ else }}{{ printf "%q" $env }}{{ end }}
SEC_USER_AGENT={{ with .Data.data.SEC_USER_AGENT }}{{ printf "%q" . }}{{ else }}""{{ end }}
ANTHROPIC_API_KEY={{ with .Data.data.ANTHROPIC_API_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
{{- /* #447: app-web's auth session JWT signing (apps/app-web/src/server/auth/config.ts)
       hard-fails in production without this. Auto-provisioned by
       AppDeployer.ensure_runtime_secrets (10.app/deploy.py) the same way
       S3 credentials are, so no manual Vault seeding step is required. */}}
SECRET_KEY={{ with .Data.data.SECRET_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
{{- /* S3-compatible raw archive (truealpha runtime contract: immutable source
       bytes in object storage, Postgres raw.fetches keeps the pointers).
       Populated by deploy.py's _ensure_minio_bucket via platform/03.minio
       create_app_bucket; endpoint defaults to the platform MinIO on the
       dokploy network. */}}
S3_ENDPOINT={{ with .Data.data.S3_ENDPOINT }}{{ printf "%q" . }}{{ else }}{{ printf "%q" (printf "http://platform-minio%s:9000" $env_suffix) }}{{ end }}
S3_ACCESS_KEY={{ with .Data.data.S3_ACCESS_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
S3_SECRET_KEY={{ with .Data.data.S3_SECRET_KEY }}{{ printf "%q" . }}{{ else }}""{{ end }}
S3_BUCKET={{ with .Data.data.S3_BUCKET }}{{ printf "%q" . }}{{ else }}"truealpha-raw"{{ end }}
S3_REGION={{ with .Data.data.S3_REGION }}{{ printf "%q" . }}{{ else }}"us-east-1"{{ end }}
{{- end }}
