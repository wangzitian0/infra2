{
    "gateway": {
        "mode": "local",
        "trustedProxies": [
            "*"
        ],
        "controlUi": {
            "dangerouslyDisableDeviceAuth": true
        }
    },
    "channels": {
        "feishu": {
            "enabled": true,
            "dmPolicy": "auto",
            "domain": "${FEISHU_DOMAIN}",
            "appId": "${FEISHU_APP_ID}",
            "appSecret": "${FEISHU_APP_SECRET}",
            "encryptKey": "${FEISHU_ENCRYPT_KEY}",
            "verificationToken": "${FEISHU_VERIFICATION_TOKEN}"
        }
    },
    "plugins": {
        "entries": {
            "feishu": {
                "enabled": true
            }
        }
    }
}