# General
DOMAIN=openclaw.zitian.party
LOG_LEVEL=INFO
# Token for internal gateway authentication
OPENCLAW_GATEWAY_TOKEN=your_secure_token_here
# Keyring password (required for credential persistence)
GOG_KEYRING_PASSWORD=change_me_to_random_string

# Network Configuration
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# LLM Configuration (OpenAI-compatible endpoint)
# Used by init-config to generate openclaw.json
LLM_PROVIDER=coding
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_ID=glm-5
LLM_MODEL_NAME=GLM-5

# Feishu Integration
# All vars are required for feishu channel to start
FEISHU_ENABLED=true
FEISHU_DOMAIN=feishu
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token_here
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key_here
