# General
DOMAIN=openclaw.zitian.party
OPENCLAW_LOG_LEVEL=info
# Optional targeted diagnostic flags, for example: telegram.http or *
OPENCLAW_DIAGNOSTICS=
# Skip startup primary-model warmup so gateway startup and Discord handling are not delayed by provider discovery.
OPENCLAW_SKIP_STARTUP_MODEL_PREWARM=1
# Disable OpenClaw's built-in cron scheduler; TianClaw uses a no-catch-up sidecar runner.
OPENCLAW_SKIP_CRON=1
# Skip interactive onboarding in automated Docker deployments.
OPENCLAW_SKIP_ONBOARDING=true
# Token for internal gateway authentication
OPENCLAW_GATEWAY_TOKEN=your_secure_token_here
# Keyring password (required for credential persistence)
GOG_KEYRING_PASSWORD=change_me_to_random_string

# Network Configuration
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# LLM Configuration (OpenAI-compatible endpoint)
# Used by init-config to generate openclaw.json
LLM_PROVIDER=github-copilot
LLM_BASE_URL=https://api.githubcopilot.com
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_ID=claude-sonnet-4.6
LLM_MODEL_NAME=Claude Sonnet 4.6

# Agent overrides
# Requires an existing OpenClaw auth/profile for the selected provider.
TIANCLAW_MODEL=openai-codex/gpt-5.5
OPENCLAW_GATEWAY_CHANNEL_HEALTH_CHECK_MINUTES=0
OPENCLAW_AGENTS_MAX_CONCURRENT=2
OPENCLAW_AGENTS_SUBAGENTS_MAX_CONCURRENT=1
OPENCLAW_CRON_MAX_CONCURRENT_RUNS=1
OPENCLAW_AGENTS_TYPING_MODE=instant
OPENCLAW_AGENTS_TYPING_INTERVAL_SECONDS=3
OPENCLAW_GROUP_VISIBLE_REPLIES=message_tool
DISCORD_NATIVE_SKILL_COMMANDS=false
TIANCLAW_GIT_SYNC_INTERVAL_SECONDS=86400
TIANCLAW_GIT_SYNC_ENABLED=true
TIANCLAW_GIT_FALLBACK_BRANCH_PREFIX=snapshot/openclaw-volume
# Optional sidecar GitHub API token for fallback snapshot PR creation and auto-merge.
# Prefer the TianClaw repo GitHub Actions workflow when available; leave this empty in that setup.
# Required scopes for fine-grained tokens if used: Contents read/write and Pull requests read/write on the TianClaw repo.
TIANCLAW_GIT_OPEN_PR_ON_FALLBACK=true
TIANCLAW_GIT_AUTO_MERGE_PR=true
TIANCLAW_GIT_DELETE_FALLBACK_BRANCH_AFTER_MERGE=true
TIANCLAW_GIT_GITHUB_REPO=wangzitian-ai/tianclaw
TIANCLAW_GIT_GITHUB_TOKEN=
TIANCLAW_CRON_RUNNER_ENABLED=true
TIANCLAW_CRON_RUNNER_INTERVAL_MS=30000
TIANCLAW_CRON_RUNNER_CLI_TIMEOUT_MS=45000
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# Discord Integration
DISCORD_ENABLED=true
DISCORD_TOKEN=your_discord_bot_token_here
# DM policy: open | pairing | disabled
DISCORD_DM_ENABLED=true
DISCORD_DM_POLICY=open
# Guild policy: open | allowlist | disabled
DISCORD_GROUP_POLICY=open
# false = reply in guild without @mention
DISCORD_GROUP_REQUIRE_MENTION=false
