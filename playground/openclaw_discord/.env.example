# General
DOMAIN=openclaw.zitian.party
OPENCLAW_LOG_LEVEL=INFO
# Optional targeted diagnostic flags, for example: telegram.http or *
OPENCLAW_DIAGNOSTICS=
# Restart the gateway if a Discord account stays disconnected after the grace window.
OPENCLAW_CHANNEL_WATCHDOG_GRACE_SECONDS=120
OPENCLAW_CHANNEL_WATCHDOG_INTERVAL_SECONDS=30
# Token for internal gateway authentication
OPENCLAW_GATEWAY_TOKEN=your_secure_token_here
# Keyring password (required for credential persistence)
GOG_KEYRING_PASSWORD=change_me_to_random_string

# Network Configuration
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789

# LLM Configuration (OpenAI-compatible endpoint)
# Used by init-config to generate openclaw.json
LLM_PROVIDER=coding
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_ID=glm-5
LLM_MODEL_NAME=GLM-5

# Agent overrides
# Requires an existing OpenClaw auth/profile for the selected provider.
TIANCLAW_MODEL=openai-codex/gpt-5.4

# Discord Integration
DISCORD_ENABLED=true
DISCORD_TOKEN=your_discord_bot_token_here
# DM policy: open | pairing | disabled
DISCORD_DM_ENABLED=true
DISCORD_DM_POLICY=open
# Guild policy: open | allowlist | disabled
DISCORD_GROUP_POLICY=open
# false = reply in guild without @mention
DISCORD_GROUP_REQUIRE_MENTION=false
