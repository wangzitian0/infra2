<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>
    <keep_alive_timeout>10</keep_alive_timeout>
    <!-- Stop all the unnecessary logging -->
    <query_thread_log remove="remove"/>
    <query_log remove="remove"/>
    <text_log remove="remove"/>
    <trace_log remove="remove"/>
    <metric_log remove="remove"/>
    <asynchronous_metric_log remove="remove"/>
    <session_log remove="remove"/>
    <part_log remove="remove"/>
    <listen_host>0.0.0.0</listen_host>
    <interserver_listen_host>0.0.0.0</interserver_listen_host>
    <interserver_http_host>op-ch</interserver_http_host>
    <!-- Single-node; kept for upstream parity -->
    <macros>
        <shard>1</shard>
        <replica>replica1</replica>
        <cluster>openpanel_cluster</cluster>
    </macros>
    <!-- NOTE: do NOT cap background_pool_size here. ClickHouse rejects startup
         (Code 36) when number_of_free_entries_in_pool_to_execute_mutation (20)
         exceeds background_pool_size * background_merges_mutations_concurrency_ratio.
         The per-query max_threads cap (users.d/op-user-config.xml) is the safe
         CPU lever; background-merge tuning needs the free-entries setting lowered
         in tandem and is intentionally left at default. -->

    <!-- Hard server-wide memory cap (absolute bytes). Without this, ClickHouse
         defaults max_server_memory_usage to ~90% of TOTAL host RAM — i.e. op-ch
         believes it owns almost the whole shared 8-core box. With no swap (by
         choice), a single heavy merge/query then trips the kernel OOM killer,
         which can kill an unrelated container (Dokploy, prod). Cap op-ch's own
         accounting at 2 GiB so it rejects/spills oversized work instead of
         growing into the host. The compose mem_limit (2.5g) is the cgroup
         backstop above this; keep mem_limit > this value so CH fails its own
         query before the kernel OOM-kills the container. -->
    <max_server_memory_usage>2147483648</max_server_memory_usage>
</clickhouse>
