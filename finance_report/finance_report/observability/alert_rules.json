{
  "$comment": "Config-as-code SigNoz alert rules for finance_report (#373/#1106). The app references FinanceReportBackendErrorLogs in apps/backend/src/observability.py; this file is the reviewable source of truth. Applied idempotently by `invoke fr-observability.shared.apply-alerts`, which routes rules to the shared Feishu/Lark bridge channel. The full SigNoz v5 log/PromQL payload is derived from this shape by libs/observability_dashboards.py + libs/alerting.py.",
  "rules": [
    {
      "signal": "logs",
      "alert_name": "FinanceReportBackendErrorLogs",
      "service_name": "finance-report-backend",
      "severity": "error",
      "threshold": 0,
      "eval_window": "5m0s",
      "frequency": "1m",
      "summary": "finance-report-backend emitted ERROR/FATAL logs in the last 5 minutes. Runbook: docs/ssot/ops.observability.md SOP-004B."
    },
    {
      "signal": "metrics",
      "alert_name": "FinanceReportHigh5xxRate",
      "service_name": "finance-report-backend",
      "severity": "critical",
      "threshold": 0.05,
      "threshold_unit": "%",
      "op": "above",
      "match_type": "all_times",
      "eval_window": "5m0s",
      "frequency": "1m",
      "promql": "sum(rate(http_server_request_count{service_name=\"finance-report-backend\",http_response_status_code_class=\"5xx\"}[5m])) / clamp_min(sum(rate(http_server_request_count{service_name=\"finance-report-backend\"}[5m])), 1)",
      "summary": "finance_report backend 5xx rate is above 5% for 5 minutes. Severity P0. Runbook: docs/ssot/ops.observability.md SOP-004C."
    },
    {
      "signal": "metrics",
      "alert_name": "FinanceReportP95LatencyHigh",
      "service_name": "finance-report-backend",
      "severity": "warning",
      "threshold": 1500,
      "threshold_unit": "ms",
      "op": "above",
      "match_type": "at_least_once",
      "eval_window": "5m0s",
      "frequency": "1m",
      "promql": "histogram_quantile(0.95, sum(rate(http_server_request_duration_bucket{service_name=\"finance-report-backend\"}[5m])) by (le))",
      "summary": "finance_report backend p95 request latency is above 1500ms. Severity P1. Runbook: docs/ssot/ops.observability.md SOP-004C."
    },
    {
      "signal": "metrics",
      "alert_name": "FinanceReportStatementParseFailureSpike",
      "service_name": "finance-report-backend",
      "severity": "error",
      "threshold": 3,
      "threshold_unit": "count",
      "op": "above",
      "match_type": "in_total",
      "eval_window": "15m0s",
      "frequency": "1m",
      "promql": "sum(increase(finance_statement_parse_outcome{outcome=~\"failure|rejected\"}[15m]))",
      "summary": "finance_report statement parse failures exceeded 3 in 15 minutes. Severity P1. Runbook: docs/ssot/ops.observability.md SOP-004C."
    },
    {
      "signal": "metrics",
      "alert_name": "FinanceReportReconciliationAnomaly",
      "service_name": "finance-report-backend",
      "severity": "error",
      "threshold": 0,
      "threshold_unit": "count",
      "op": "above",
      "match_type": "at_least_once",
      "eval_window": "15m0s",
      "frequency": "1m",
      "promql": "sum(increase(finance_reconciliation_match_outcome{outcome=~\"failed|error|anomaly\"}[15m]))",
      "summary": "finance_report reconciliation anomaly or failure was observed. Severity P1. Runbook: docs/ssot/ops.observability.md SOP-004C."
    },
    {
      "signal": "metrics",
      "alert_name": "FinanceReportRateLimitSaturation",
      "service_name": "finance-report-backend",
      "severity": "warning",
      "threshold": 10,
      "threshold_unit": "count",
      "op": "above",
      "match_type": "in_total",
      "eval_window": "5m0s",
      "frequency": "1m",
      "promql": "sum(increase(finance_rate_limit_rejected{service_name=\"finance-report-backend\"}[5m]))",
      "summary": "finance_report rate-limit rejections exceeded 10 in 5 minutes. Severity P2. Runbook: docs/ssot/ops.observability.md SOP-004C."
    },
    {
      "signal": "metrics",
      "alert_name": "FinanceReportAsyncTaskFailures",
      "service_name": "finance-report-backend",
      "severity": "error",
      "threshold": 0,
      "threshold_unit": "count",
      "op": "above",
      "match_type": "at_least_once",
      "eval_window": "5m0s",
      "frequency": "1m",
      "promql": "sum(increase(finance_async_parse_failure{service_name=\"finance-report-backend\"}[5m]))",
      "summary": "finance_report async statement parse task failure was observed. Severity P1. Runbook: docs/ssot/ops.observability.md SOP-004C."
    }
  ]
}
